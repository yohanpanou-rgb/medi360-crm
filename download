import React, { createContext, useContext, useState, useEffect } from 'react';

const AuthContext = createContext(null);

const USERS = [
  { id: 1, email: 'admin@medi360.gr', password: 'medi360', name: 'Johan Panou', role: 'admin', initials: 'JP' },
  { id: 2, email: 'demo@medi360.gr', password: 'demo123', name: 'Demo User', role: 'user', initials: 'DU' },
];

export function AuthProvider({ children }) {
  const [user, setUser] = useState(() => {
    try { return JSON.parse(sessionStorage.getItem('m360_user')) || null; } catch { return null; }
  });

  useEffect(() => {
    if (user) sessionStorage.setItem('m360_user', JSON.stringify(user));
    else sessionStorage.removeItem('m360_user');
  }, [user]);

  const login = async (email, password) => {
    await new Promise(r => setTimeout(r, 600)); // simulate network
    const found = USERS.find(u => u.email === email && u.password === password);
    if (!found) throw new Error('Λάθος email ή κωδικός');
    const { password: _, ...safe } = found;
    setUser(safe);
  };

  const logout = () => setUser(null);

  return (
    <AuthContext.Provider value={{ user, login, logout, isAuthenticated: !!user }}>
      {children}
    </AuthContext.Provider>
  );
}

export function useAuth() { return useContext(AuthContext); }
